[run]
# Fresh-install tests copy source files to a tempdir; coverage tracks
# those copies and warns "no source" because they live outside the repo.
disable_warnings = no_source

[report]
# Show line numbers missed for any file with > 0% coverage
show_missing = True
# Skip trivial lines (pass, raise NotImplementedError, etc.)
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
