# ─── Bloomsberg News — environment variables ───────────────
# Copy this file to `.env` and fill in any keys you have.
# Missing keys are fine; the corresponding scrapers will be skipped.
# DO NOT commit your real `.env` — it is in .gitignore.

# ─── Telegram bot token (optional) ─────────────────────────
# Get one from @BotFather on Telegram: https://t.me/BotFather
# Without this, the daily Telegram digest is skipped.
TELEGRAM_BOT_TOKEN=

# ─── NewsAPI key (optional) ────────────────────────────────
# Free tier at https://newsapi.org — 100 requests/day.
# Without this, the technology/science/business headline feed is skipped.
NEWS_API_KEY=

# ─── Finnhub key (optional) ────────────────────────────────
# Free tier at https://finnhub.io — 60 requests/minute.
# Without this, the market news feed is skipped.
FINNHUB_API_KEY=
